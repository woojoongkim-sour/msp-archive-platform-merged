# ── 필수 ─────────────────────────────────────────────────────────────
# OpenAI API (RAG 채팅, Adaptive RAG 분류용)
OPENAI_API_KEY=your-openai-api-key-here

# HuggingFace API (BGE-m3 임베딩용)
HF_TOKEN=your-huggingface-token-here

# JWT 인증 시크릿 (랜덤 문자열 권장)
SECRET_KEY=your-random-secret-key-here

# PostgreSQL (docker-compose 기본값과 일치해야 함)
DATABASE_URL=postgresql://user:password@postgres/msp_archive

# 초기 관리자 계정 (최초 실행 시 자동 생성)
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=change-me-on-first-run

# ── 선택 ─────────────────────────────────────────────────────────────
# Redis (ARQ 워커, 실시간 진행 상황 SSE, Pub/Sub)
REDIS_URL=redis://redis:6379/0

# Adaptive RAG 에스컬레이션 임계값 (0~1, 기본 0.3)
# dense_score 가 이 값 미만이면 simple → complex 로 에스컬레이션
ESCALATION_SCORE_THRESHOLD=0.3

# Zammad 연동 (SR 티켓 수집용, 미설정 시 비활성)
ZAMMAD_API_URL=https://your-zammad-instance/
ZAMMAD_API_TOKEN=your-zammad-api-token
