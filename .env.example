# OpenAI API (RAG 채팅용 - 필수)
OPENAI_API_KEY=your-openai-api-key-here

# HuggingFace API (BGE-m3 임베딩용 - 필수)
HF_TOKEN=your-huggingface-token-here

# JWT 인증 시크릿 (랜덤 문자열 권장 - 필수)
SECRET_KEY=your-random-secret-key-here

# PostgreSQL (docker-compose 기본값과 일치해야 함)
DATABASE_URL=postgresql://user:password@postgres/msp_archive

# 초기 관리자 계정 (최초 실행 시 자동 생성)
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=change-me-on-first-run
